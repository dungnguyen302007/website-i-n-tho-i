{
  "entities": {
    "Product": {
      "title": "Product",
      "description": "A mobile phone or accessory product.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "price": { "type": "number" },
        "oldPrice": { "type": "number" },
        "category": { "type": "string" },
        "image": { "type": "string" },
        "description": { "type": "string" },
        "specs": { "type": "object" },
        "featured": { "type": "boolean" }
      },
      "required": ["name", "price", "category", "image", "description", "specs"]
    },
    "NewsItem": {
      "title": "News Item",
      "description": "A tech news article or review.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "summary": { "type": "string" },
        "content": { "type": "string" },
        "image": { "type": "string" },
        "date": { "type": "string" }
      },
      "required": ["title", "summary", "content", "image", "date"]
    },
    "ContactMessage": {
      "title": "Contact Message",
      "description": "User feedback or inquiry from the contact form.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "message": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "email", "message", "createdAt"]
    }
  },
  "firestore": {
    "/products/{productId}": {
      "schema": "Product",
      "description": "Collection of products for sale."
    },
    "/news/{newsId}": {
      "schema": "NewsItem",
      "description": "Collection of news articles."
    },
    "/messages/{messageId}": {
      "schema": "ContactMessage",
      "description": "Collection of user contact messages."
    }
  }
}
