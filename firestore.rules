rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // Phase 3: Primitives
    function isSignedIn() {
      return request.auth != null;
    }

    function isVerified() {
      return isSignedIn() && request.auth.token.email_verified == true;
    }

    function isAdmin() {
      return isSignedIn() && request.auth.token.email == 'nguyenvandung63664@gmail.com';
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // 1. Products
    match /products/{productId} {
      function isValidProduct(data) {
        return data.name is string && data.name.size() > 0 && data.name.size() <= 200
            && data.price is number && data.price >= 0
            && data.category is string && data.category.size() > 0
            && data.image is string && data.image.size() > 0
            && data.description is string && data.description.size() <= 2000
            && data.specs is map;
      }

      allow read: if true;
      allow create: if isAdmin() && isValidId(productId) && isValidProduct(incoming());
      allow update: if isAdmin() && isValidProduct(incoming());
      allow delete: if isAdmin();
    }

    // 2. News
    match /news/{newsId} {
      function isValidNews(data) {
        return data.title is string && data.title.size() > 0 && data.title.size() <= 200
            && data.summary is string && data.summary.size() <= 1000
            && data.content is string
            && data.image is string
            && data.date is string;
      }

      allow read: if true;
      allow create: if isAdmin() && isValidId(newsId) && isValidNews(incoming());
      allow update: if isAdmin() && isValidNews(incoming());
      allow delete: if isAdmin();
    }

    // 3. Contact Messages
    match /messages/{messageId} {
      function isValidMessage(data) {
        return data.name is string && data.name.size() > 0 && data.name.size() <= 100
            && data.email is string && data.email.size() > 0 && data.email.matches('^.+@.+$')
            && data.message is string && data.message.size() > 0 && data.message.size() <= 5000
            && data.createdAt is timestamp;
      }

      allow create: if isValidId(messageId) && isValidMessage(incoming());
      allow read: if isAdmin(); // Only admin can read messages
    }
  }
}
